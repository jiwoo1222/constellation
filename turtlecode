def connect_stars(stars):
    """Connect the stars in the constellation."""
    star_turtle.penup()
    star_turtle.goto(stars[0])  # Start from the first star
    star_turtle.pendown()
    
    for star in stars[1:]:
        star_turtle.goto(star)  # Draw line to each star

