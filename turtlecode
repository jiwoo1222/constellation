import turtle


def draw_star(x, y):
    """Draw a star at the given coordinates."""
    star_turtle.penup()
    star_turtle.goto(x, y)
    star_turtle.pendown()
    star_turtle.dot(5, "yellow")  # Draw a yellow dot for the star

